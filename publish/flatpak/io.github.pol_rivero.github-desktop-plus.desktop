[Desktop Entry]
Name=Desktop Plus
GenericName=Git Client
Comment=GitHub Desktop fork with advanced functionality and improvements.
Exec=start-desktop-plus %U 
Icon=io.github.pol_rivero.github-desktop-plus
Type=Application
Terminal=false
StartupNotify=true
StartupWMClass=desktop-plus
MimeType=x-scheme-handler/x-github-client;x-scheme-handler/x-github-desktop-auth;x-scheme-handler/x-github-desktop-dev-auth;
Categories=Development;
Keywords=git;github;gitlab;bitbucket;
